{
  "name": "Enrollment",
  "type": "object",
  "properties": {
    "serviceId": {
      "type": "string"
    },
    "serviceName": {
      "type": "string"
    },
    "studentName": {
      "type": "string"
    },
    "studentEmail": {
      "type": "string"
    },
    "studentPhone": {
      "type": "string"
    },
    "grade": {
      "type": "string"
    },
    "school": {
      "type": "string"
    },
    "specialRequests": {
      "type": "string"
    },
    "instructor": {
      "type": "string"
    },
    "sessionDate": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "online",
        "in-person"
      ],
      "default": "online"
    },
    "provider": {
      "type": "string",
      "enum": [
        "stripe",
        "paypal"
      ]
    },
    "paymentMethod": {
      "type": "string"
    },
    "subtotal": {
      "type": "number"
    },
    "discount": {
      "type": "number",
      "default": 0
    },
    "tax": {
      "type": "number",
      "default": 0
    },
    "total": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "CAD"
    },
    "couponCode": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "refunded",
        "failed",
        "canceled"
      ],
      "default": "pending"
    },
    "transactionId": {
      "type": "string"
    },
    "invoiceNumber": {
      "type": "string"
    },
    "paidDate": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "serviceName",
    "studentName",
    "studentEmail",
    "provider",
    "total",
    "status"
  ]
}